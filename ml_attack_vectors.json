  "attack_vectors": [
    {
      "id": "AV-001",
      "category": "Pickle-Based Formats",
      "format": "Pickle Files",
      "extensions": [".pkl", ".pickle", ".dill", ".bin", ".pt", ".pth", ".ckpt"],
      "severity": "CRITICAL",
      "vulnerabilities": [
        {
          "type": "Arbitrary Code Execution",
          "attack_vector": "Malicious pickle opcodes",
          "description": "REDUCE, INST, OBJ, NEWOBJ, STACK_GLOBAL opcodes can execute arbitrary code during unpickling",
          "impact": "Full system compromise"
        },
        {
          "type": "Module Import Injection",
          "attack_vector": "Dangerous module imports",
          "description": "Import os, subprocess, sys modules and execute system commands",
          "impact": "Code execution with model loading privileges"
        },
        {
          "type": "Code Obfuscation",
          "attack_vector": "Encoded payloads",
          "description": "Base64/hex-encoded malicious code bypassing string detection",
          "impact": "Bypass of static analysis"
        },
        {
          "type": "Data Exfiltration",
          "attack_vector": "Network communication",
          "description": "Embedded URLs, IPs, socket connections to C&C servers",
          "impact": "Sensitive data theft"
        },
        {
          "type": "File System Manipulation",
          "attack_vector": "File I/O operations",
          "description": "Read/write files, access configurations during unpickling",
          "impact": "Configuration tampering, credential theft"
        },
        {
          "type": "Binary Embedding",
          "attack_vector": "Embedded executables",
          "description": "PE, ELF, Mach-O binaries in pickle data",
          "impact": "Malware distribution"
        }
      ]
    },
